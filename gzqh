restart_service() {
  while true; do
    show_header
    echo "服务控制"
    echo
    echo "1) 启动服务"
    echo "2) 停止服务"
    echo "3) 重启服务"
    echo "4) 查看服务状态"
    echo "0) 返回"
    echo
    read -rp "请选择: " c
    case "$c" in
      1)
        systemctl start "$SERVICE"
        systemctl enable "$SERVICE" >/dev/null 2>&1 || true
        systemctl status "$SERVICE" --no-pager -l | sed -n '1,30p'
        pause ;;
      2)
        systemctl stop "$SERVICE" || true
        systemctl status "$SERVICE" --no-pager -l | sed -n '1,20p' || true
        pause ;;
      3)
        reload_restart
        systemctl status "$SERVICE" --no-pager -l | sed -n '1,30p'
        pause ;;
      4)
        systemctl status "$SERVICE" --no-pager -l | sed -n '1,30p'
        pause ;;
      0) return ;;
      *) warn "无效选择"; sleep 1 ;;
    esac
  done
}
