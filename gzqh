force_backup() {
  show_header
  local backups idx selected host port count
  backups=$(get_backup_list)
  IFS=',' read -ra arr <<< "$backups"
  echo "备用列表:"
  count=0
  for item in "${arr[@]}"; do
    count=$((count + 1))
    echo "  ${count}) ${item}"
  done
  read -rp "选择备用编号 [1]: " idx
  idx=${idx:-1}
  if ! [[ "$idx" =~ ^[0-9]+$ ]] || (( idx < 1 || idx > count )); then
    err "编号无效"
    pause
    return
  fi
  selected=${arr[$((idx - 1))]}
  host=${selected%:*}
  port=${selected##*:}
  warn "将手动锁定到备用#${idx}: ${host}:${port}"
  read -rp "确认请输入 y: " y
  [[ "$y" == "y" ]] || return
  python3 - <<PY
import importlib.util
spec = importlib.util.spec_from_file_location('fo', '$SCRIPT_FILE')
fo = importlib.util.module_from_spec(spec)
spec.loader.exec_module(fo)
fo.switch_target('$host', int('$port'))
st = fo.load_state()
st['active']='backup:$((idx - 1))'; st['backup_index']=$((idx - 1)); st['manual_hold']='backup'; st['fail_count']=0; st['recover_count']=0; st['last_change']=int(__import__('time').time())
fo.save_state(st)
print('switched to backup#$idx: $host:$port')
PY
  show_rules
  pause
}

