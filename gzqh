update_self() {
  show_header
  warn "将从 GitHub release 下载最新包并覆盖更新，保留当前 service 参数。"
  read -rp "确认请输入 yes: " ans
  [[ "$ans" == "yes" ]] || return
  local tmpdir
  tmpdir=$(mktemp -d /tmp/gzqh-update.XXXXXX)
  cd "$tmpdir"
  curl -fsSL -o gzqh-portable.zip https://github.com/saotu/gzqh-portable/releases/latest/download/gzqh-portable.zip
  unzip -q -o gzqh-portable.zip
  cd gzqh-portable
  bash install.sh
  ok "更新完成"
  pause
}

uninstall_all() {
  show_header
  warn "将卸载 gzqh / ss-failover，并删除 service、脚本、状态和日志轮转配置"
  read -rp "确认请输入 yes: " ans
  [[ "$ans" == "yes" ]] || return
  systemctl stop "$SERVICE" 2>/dev/null || true
  systemctl disable "$SERVICE" 2>/dev/null || true
  rm -f "$SERVICE_FILE"
  rm -f "$SCRIPT_FILE"
  rm -f "$LOGROTATE_FILE"
  rm -rf /opt/ss-failover
  rm -f /usr/local/bin/gzqh
